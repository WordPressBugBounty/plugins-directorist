{
	"compilerOptions": {
	  "target": "ESNext",
	  "lib": ["DOM", "DOM.Iterable", "ESNext"],
	  "module": "ESNext",
	  "moduleResolution": "Node",
	  "strict": true,
	  "jsx": "react-jsx",
	  "esModuleInterop": true,
	  "skipLibCheck": true,
	  "forceConsistentCasingInFileNames": true,
	  "outDir": "assets",
	  "declaration": true,
	  "declarationDir": "build-types",
	  "baseUrl": ".",
	  "paths": {
		"@/*": [ "./resources/js/*" ]
	  }
	},
	"include": ["resources/js"],
	"exclude": ["node_modules", "dist", "assets"],
}